{
    "name": "@spritzlabs/sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for building apps on Spritz — censorship-resistant Web3 chat",
    "author": "Spritz Labs",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Spritz-Labs/spritz-typescript-sdk.git"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "spritz",
        "web3",
        "chat",
        "sdk",
        "ethereum",
        "waku",
        "logos",
        "decentralized"
    ],
    "packageManager": "yarn@3.2.3+sha512.f26f951f67de0c6a33ee381e5ff364709c87e70eb5e65c694e4facde3512f1fa80b8679e6ba31ce7d340fbb46f08dd683af9457e240f25a204be7427940d767e"
}
